    "tabsVisible.app.detail": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep this app installed. Enable Tabs Visible Sidebar from coterm Sidebar Extensions, then choose the extension sidebar provider from the sidebar footer puzzle button."
          }
        }
      }
    },
    "tabsVisible.app.scopes": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The extension shows workspaces as disclosure groups and lists each workspace surface underneath."
          }
        }
      }
    },
    "tabsVisible.app.title": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tabs Visible Sidebar"
          }
        }
      }
    }
  },
  "version": "1.0"
}
