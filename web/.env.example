RESEND_API_KEY=
COTERM_FEEDBACK_FROM_EMAIL=
COTERM_FEEDBACK_RATE_LIMIT_ID=

# coterm Founder's Edition welcome email. /api/stripe/founders-welcome verifies the
# Stripe webhook signature with this endpoint secret, then sends the welcome email
# via Resend (To customer, CC the founders). Leave the secret empty to disable the
# route. COTERM_FOUNDERS_FROM_EMAIL overrides the sender (defaults to
# austin@manaflow.ai) and must be on a Resend-verified domain.
COTERM_FOUNDERS_FROM_EMAIL=
STRIPE_FOUNDERS_WEBHOOK_SECRET=

# Stack Auth (https://stack-auth.com), required for the /handler/* routes
# and the mac app sign-in flow.
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Local/Postgres database. `bun db:*` derives the local port from COTERM_PORT by default:
# DATABASE_URL uses localhost:${COTERM_PORT + 10000}. CI should set explicit URLs.
DATABASE_URL=
DIRECT_DATABASE_URL=

# Cloud VM providers (manaflow-owned keys, no BYO). See scratch/vm-experiments for images.
# Global create kill switch. Set to 0/false/off to block new paid provider creates while keeping
# list, attach, and delete endpoints available.
COTERM_VM_CREATE_ENABLED=1
# Which provider a fresh `coterm vm new` picks if the client doesn't specify one.
COTERM_VM_DEFAULT_PROVIDER=e2b
# Dev-only escape hatch for image experiments. Leave unset in Vercel production/staging/preview so
# image ids must be present in services/vms/images/manifest.json.
COTERM_VM_ALLOW_UNMANIFESTED_IMAGES=
# Optional comma-separated same-origin exceptions for cookie-authenticated browser mutations.
COTERM_VM_ALLOWED_ORIGINS=
COTERM_VM_E2B_ENABLED=1
E2B_API_KEY=
# E2B cotermd WebSocket PTY template. Produced by web/scripts/build-cloud-vm-images.ts.
E2B_COTERMD_WS_TEMPLATE=cotermd-ws:proxy-20260424a
# Legacy scratch template. Pass explicitly with --image if needed.
E2B_SANDBOX_TEMPLATE=coterm-sandbox:v0-71a954b8e53b
COTERM_VM_FREESTYLE_ENABLED=0
FREESTYLE_API_KEY=
FREESTYLE_SANDBOX_SNAPSHOT=sc-mt237w1nd7c7673bd03m

# Cloud VM database. Local dev derives DATABASE_URL from COTERM_PORT. Staging/production use the
# Vercel Marketplace AWS Aurora PostgreSQL OIDC/RDS IAM env set below.
COTERM_DB_DRIVER=
COTERM_DB_POOL_MAX=5
# Verify AWS RDS server certificates. Leave unset for the current Vercel Marketplace Aurora
# databases so Node uses its default trust store.
COTERM_DB_SSL_REJECT_UNAUTHORIZED=
AWS_ROLE_ARN=
AWS_REGION=
PGDATABASE=
PGHOST=
PGPORT=
PGUSER=

# Optional Stack Auth create-credit gating. Leave this empty for active-limit-only
# free-plan enforcement. Set an item id only when the free plan should consume
# one team-scoped create-credit item per successful create.
COTERM_VM_PLAN_FREE_CREATE_CREDIT_ITEM_ID=
COTERM_VM_PLAN_FREE_CREATE_CREDIT_COST=
# Optional global or provider-specific overrides. Paid plans use create credits only when
# a plan-specific or global item id is configured.
COTERM_VM_CREATE_CREDIT_COST=
COTERM_VM_CREATE_CREDIT_COST_E2B=
COTERM_VM_CREATE_CREDIT_COST_FREESTYLE=
COTERM_VM_CREATE_CREDIT_ITEM_ID=

# OpenTelemetry/Axiom.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=

# Web analytics. The macOS app uses the Swift PostHog SDK directly; update
# Sources/PostHogAnalytics.swift when changing the native project key.
NEXT_PUBLIC_POSTHOG_KEY=phc_rRRqoNMdWb5ikbnHwC7EXWKBmYY7VvKJVCLaDqTm97ep
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com

# Optional iOS native analytics proxy at /api/analytics/events.
POSTHOG_PROJECT_KEY=phc_rRRqoNMdWb5ikbnHwC7EXWKBmYY7VvKJVCLaDqTm97ep
POSTHOG_HOST=https://us.i.posthog.com

# High-signal bug alerts. Set the shared secret in both the web deployment and
# macOS app environment when you want /api/bug-alerts to reject unauthenticated
# posts.
COTERM_BUG_ALERTS_WEBHOOK_URL=
COTERM_BUG_ALERTS_SHARED_SECRET=
