    "mobile.setupHelp.intro": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To see your computer's terminals here, four things have to line up. The step you are on is marked below."
          }
        }
      }
    },
    "mobile.setupHelp.introReference": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "To see your computer's terminals here, four things have to line up."
          }
        }
      }
    },
    "mobile.setupHelp.lanBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No Tailscale? On the same Wi-Fi you can still connect by typing the computer's local address and port by hand in Add Computer. That link is unencrypted, so only use it on a network you trust."
          }
        }
      }
    },
    "mobile.setupHelp.macAppBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Install coterm on your computer and leave it running, signed in to the same account. The phone pairs to a running coterm build, so a quit or never-installed app is the most common reason pairing does nothing."
          }
        }
      }
    },
    "mobile.setupHelp.macAppLink": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Download coterm"
          }
        }
      }
    },
    "mobile.setupHelp.macAppTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Run coterm on your computer"
          }
        }
      }
    },
    "mobile.setupHelp.mismatchBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the computer rejects this device's sign-in, the two are on different coterm accounts or this device's session is stale. Sign this phone in to the computer's account (or sign the computer in to this one), then pair again."
          }
        }
      }
    },
    "mobile.setupHelp.mismatchTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Match the account"
          }
        }
      }
    },
    "mobile.setupHelp.networkBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Scanning the computer's QR code needs Tailscale: the computer only shows a code when it has a Tailscale address your phone can reach. Install Tailscale on both, sign both in to the same tailnet, and the code appears."
          }
        }
      }
    },
    "mobile.setupHelp.networkTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get them on the same network"
          }
        }
      }
    },
    "mobile.setupHelp.sameAccountFooter": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The computer and this phone must be signed in to the same coterm account, and on the same tailnet (or the same Wi-Fi for a manual local connection)."
          }
        }
      }
    },
    "mobile.setupHelp.signInBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in to coterm on this phone with the same account the paired computer uses. Without that, there is nothing to connect to."
          }
        }
      }
    },
    "mobile.setupHelp.signInTitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sign in"
          }
        }
      }
    },
