        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Presence is the Mac's own heartbeat to the presence service, which is currently a DEV-only feature. Stable coterm Macs don't announce it yet, so a Mac you're connected to may show no server heartbeat. If presence says online but This phone is not connected, the Mac is reachable elsewhere but not from your phone, usually a Tailscale or route problem."
          }
        }
