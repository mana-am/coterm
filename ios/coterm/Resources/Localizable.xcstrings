        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set Up Computer"
          }
        }
      }
    },
    "mobile.setupHelp.unreachableBody": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You have paired this computer before but it is not reachable now. Wake it, make sure coterm is running, and confirm both devices are on the same tailnet or Wi-Fi. Then reconnect."
          }
        }
      }
    },
