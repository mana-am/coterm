    "mobile.pairing.connectTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Your Mac may be asleep or off Tailscale. Make sure it's awake and on the same Tailscale network."
          }
        }
      }
    },
    "mobile.pairing.connectionDroppedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connected to %@:%d, but the host closed the connection. Check that the host app is still running."
          }
        }
      }
    },
    "mobile.pairing.connectionFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Could not reach %@:%d. Check that the host is reachable over Tailscale or LAN and that the port is correct."
          }
        }
      }
    },
    "mobile.pairing.connectionTimedOutFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No response from %@:%d. Make sure the host app is open and accepting mobile connections."
          }
        }
      }
    },
    "mobile.pairing.dnsFailedFormat": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Couldn't resolve %@. Check that Tailscale is connected on both devices."
          }
        }
      }
