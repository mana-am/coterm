    "cli.claude-teams.usage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Usage: coterm claude-teams [claude-args...]\n\nLaunch Claude Code with agent teams enabled.\n\nThis command:\n  - defaults Claude teammate mode to auto\n  - sets a tmux-like environment so Claude auto mode uses coterm splits\n  - sets CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS=1\n  - prepends a private tmux shim to PATH\n  - forwards all remaining arguments to claude\n\nThe tmux shim translates supported tmux window/pane commands into coterm\nworkspace and split operations in the current coterm session.\n\nExamples:\n  coterm claude-teams\n  coterm claude-teams --continue\n  coterm claude-teams --model sonnet"
          }
        }
      }
    },
