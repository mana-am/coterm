      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "An off-screen terminal must stay off-screen this long before its renderer memory is reclaimed."
          }
        }
      }
    },
    "settings.terminal.rendererRealization.maxWarmRenderers": {
      "extractionState": "manual",
